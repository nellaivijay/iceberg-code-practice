# Storage Backend Configuration
STORAGE_BACKEND=minio
# Options: minio, objectscale

# MinIO Configuration
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ObjectScale Configuration
OBJECTSCALE_ENDPOINT=http://localhost:6080
OBJECTSCALE_ACCESS_KEY=admin
OBJECTSCALE_SECRET_KEY=password

# Apache Polaris Configuration
POLARIS_PORT=8181
POLARIS_HOST=0.0.0.0
POLARIS_URI=http://localhost:8181/api/catalog

# Spark Configuration
SPARK_HOME=/opt/spark
SPARK_MASTER=spark://spark-master:7077
SPARK_WORKER=spark://spark-master:7077
SPARK_HISTORY_PORT=18080
SPARK_EVENT_LOGS=s3a://spark-logs/

# Spark History Server Configuration
SPARK_HISTORY_USER=spark-history-user
SPARK_HISTORY_PASSWORD=spark-history-password

# MySQL Configuration
MYSQL_ROOT_PASSWORD=iceberg_root
MYSQL_DATABASE=cdc_source
MYSQL_USER=iceberg_user
MYSQL_PASSWORD=iceberg_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Kafka Configuration
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=localhost:9092
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_AUTO_CREATE_TOPICS_ENABLE=true
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_LOG_SEGMENT_BYTES=1073741824

# Zookeeper Configuration
ZOOKEEPER_CLIENT_PORT=2181
ZOOKEEPER_TICK_TIME=2000

# Debezium Configuration
BOOTSTRAP_SERVERS=kafka:9092
GROUP_ID=debezium-group
CONFIG_STORAGE_TYPE=memory
OFFSET_STORAGE_TOPIC=debezium-offsets
OFFSET_STORAGE_REPLICATION_FACTOR=1
ADVERTISED_HOST_NAME=debezium
CONNECT_CONFIG_TOPIC=debezium-config
CONNECT_STATUS_STORAGE_TOPIC=debezium-status
CONNECT_PLUGIN_PATH=/kafka/connect/plugins
CONNECT_KEY_CONVERTER=org.apache.kafka.connect.storage.StringConverter
CONNECT_VALUE_CONVERTER=org.apache.kafka.connect.storage.StringConverter
CONNECT_REST_PORT=8083
CONNECT_REST_ADVERTISED_HOST_NAME=debezium

# Network Configuration
ICEBERG_PRACTICE_NETWORK=iceberg-practice-network

# Paths
PROJECT_DIR=/home/ramdov/projects/iceberg-code-practice
SAMPLE_DIR=/home/ramdov/projects/iceberg-code-practice/data/sample
SOLUTIONS_DIR=/home/ramdov/projects/iceberg-code-practice/solutions
NOTEBOOKS_DIR=/home/ramdov/projects/iceberg-code-practice/notebooks
LOG_DIR=/home/ramdov/projects/iceberg-code-practice/logs

# Sample Data Configuration
NUM_CUSTOMERS=1000
NUM_PRODUCTS=200
NUM_ORDERS=5000
NUM_TRANSACTIONS=10000
NUM_EVENTS=20000

# Resource Limits
SPARK_MASTER_MEMORY=1Gi
SPARK_MASTER_CPU=500m
SPARK_WORKER_MEMORY=1Gi
SPARK_WORKER_CPU=500m
POLARIS_MEMORY=1Gi
POLARIS_CPU=500m
SPARK_HISTORY_MEMORY=2Gi
SPARK_HISTORY_CPU=1000m
